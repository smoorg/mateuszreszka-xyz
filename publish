#!/bin/sh

copy-nginx() {
    echo "Copy NGINX config..."
    rsync -rvz --no-owner nginx $host:/etc/nginx/sites-available/mateuszreszka.xyz
    
    ssh debian@$host << EOF
src=/usr/local/etc/nginx/sites-available/mateuszreszka.xyz
dest=/usr/local/etc/nginx/sites-enabled/mateuszreszka.xyz
if [ ! -f \$dest ]; then 
    echo "Adding a new symlink..."
    ln -s \$src \$dest
fi
EOF
}

host=$1
[ -z "$1" ] && echo "missing host" && exit 1

set -xe
rm -fr public/
hugo
echo "Copy html page..."
rsync -crvz --no-perms --delete public/ $host:/usr/local/www/nginx/mateuszreszka-xyz/html/

#rm -fr public/
#hugo --config config.gemini.yml
#echo "Copy gemini page..."
#rsync -crvz --no-perms --delete public/ $host:/var/gemini/

# needed just once
[[ "$2" =~ "nginx" ]] && copy-nginx

echo "All Done!"
